# ============================================================
# Modelo de variáveis de ambiente — COPIE para .env e preencha.
# NUNCA coloque segredos reais neste arquivo (.env.example é versionado).
# O .env real é ignorado pelo git.
# ============================================================

# --- LLM / IA (opcional; a seleção/resumo é feita pelo agente) ---
ANTHROPIC_API_KEY=

# --- Google (Gmail via conector já autorizado; preencha só se usar API direta) ---
GOOGLE_APPLICATION_CREDENTIALS=credentials.json

# --- Publicação no GitHub Pages ---
# Repositório onde a newsletter é publicada (ex.: usuario/minha-newsletter)
GITHUB_REPO=
# URL pública do GitHub Pages (ex.: https://usuario.github.io/minha-newsletter/)
NEWSLETTER_PUBLIC_URL=
# Token de acesso pessoal do GitHub (classic ou fine-grained com escopo 'repo').
# Usado pelo publish_git.py para dar push sem pedir senha.
GITHUB_TOKEN=

# --- Notificação WhatsApp via CallMeBot ---
# Passo a passo: https://www.callmebot.com/blog/free-api-whatsapp-messages/
# 1) Adicione o número +34 644 51 95 23 aos contatos
# 2) Envie "I allow callmebot to send me messages"
# 3) Você recebe uma apikey de volta
CALLMEBOT_PHONE=          # seu número com DDI, ex.: +5511999998888
CALLMEBOT_APIKEY=
